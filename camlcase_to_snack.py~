#!/usr/bin/env python3
# filename: camel_to_snake_ast.py
"""
使用 clang 的 Python 绑定进行语法树分析
更准确，但需要安装 clang
"""

import clang.cindex
from clang.cindex import CursorKind
import os
import sys

def camel_to_snake(name):
    """同上的转换函数"""
    import re
    s1 = re.sub(r'(.)([A-Z][a-z]+)', r'\1_\2', name)
    s2 = re.sub(r'([a-z0-9])([A-Z])', r'\1_\2', s1)
    s3 = re.sub(r'^([A-Z]+)_', lambda m: m.group(1).lower() + '_', s2)
    return s3.lower()

def is_camel_case(name):
    """检测是否是驼峰命名"""
    if not name:
        return False
    if '_' in name:
        return False
    # 至少有一个小写字母后接大写字母
    return any(c.islower() and i+1 < len(name) and name[i+1].isupper() 
               for i, c in enumerate(name))

class RenameVisitor:
    def __init__(self, tu):
        self.tu = tu
        self.changes = []
        self.identifiers = set()
    
    def visit(self, node):
        # 收集函数、变量、结构体等标识符
        if node.kind in [
            CursorKind.FUNCTION_DECL,
            CursorKind.VAR_DECL,
            CursorKind.STRUCT_DECL,
            CursorKind.ENUM_DECL,
            CursorKind.PARM_DECL,
            CursorKind.TYPEDEF_DECL,
            CursorKind.FIELD_DECL,
        ]:
            name = node.spelling
            if name and is_camel_case(name):
                snake_name = camel_to_snake(name)
                if snake_name != name:
                    self.identifiers.add((name, snake_name))
        
        # 递归访问子节点
        for child in node.get_children():
            self.visit(child)
    
    def get_identifiers(self):
        return self.identifiers

def process_file_with_clang(filename):
    """使用 clang 分析单个文件"""
    index = clang.cindex.Index.create()
    
    # 编译参数（根据您的项目调整）
    args = [
        '-I/usr/include',
        '-I/usr/lib/clang/15/include',  # 调整 clang 版本
        '-D__KERNEL__',
        '-DDEBUG',
    ]
    
    try:
        tu = index.parse(filename, args=args)
    except Exception as e:
        print(f"解析 {filename} 失败: {e}")
        return set()
    
    visitor = RenameVisitor(tu)
    visitor.visit(tu.cursor)
    return visitor.get_identifiers()

def main():
    if len(sys.argv) < 2:
        print("用法: python camel_to_snake_ast.py <文件或目录>")
        sys.exit(1)
    
    path = sys.argv[1]
    
    if os.path.isfile(path):
        files = [path]
    else:
        files = []
        for root, _, filenames in os.walk(path):
            for f in filenames:
                if f.endswith(('.c', '.h', '.cpp', '.hpp')):
                    files.append(os.path.join(root, f))
    
    all_identifiers = set()
    for f in files:
        print(f"分析: {f}")
        identifiers = process_file_with_clang(f)
        all_identifiers.update(identifiers)
    
    # 输出替换映射
    with open('rename_mapping.txt', 'w', encoding='utf-8') as f:
        for old, new in sorted(all_identifiers):
            f.write(f"{old} -> {new}\n")
    
    print(f"找到 {len(all_identifiers)} 个需要转换的标识符")
    print("映射已保存到 rename_mapping.txt")
    
    # 使用 sed 批量替换
    with open('do_rename.sh', 'w', encoding='utf-8') as f:
        f.write("#!/bin/bash\n")
        f.write("# 自动生成的替换脚本\n")
        f.write(f"cd {os.path.abspath(path)}\n")
        for old, new in sorted(all_identifiers, key=lambda x: len(x[0]), reverse=True):
            # 先替换整个单词，避免部分匹配
            f.write(f"find . -name '*.c' -o -name '*.h' | xargs sed -i 's/\\b{old}\\b/{new}/g'\n")
    
    print("已生成替换脚本 do_rename.sh")
    print("运行: bash do_rename.sh 执行替换")

if __name__ == "__main__":
    # 需要先安装 clang 的 Python 绑定
    # pip install clang
    # 并设置 libclang 路径
    clang.cindex.Config.set_library_path('/usr/lib/llvm-15/lib')
    
    main()
